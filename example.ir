fn @max(i64 %0, i64 %1) -> i64 {
bb0():
    %2 = icmp.gt %0, %1
    brif %2, bb1(%0), bb2(%1)
bb1(i64 %3):
    ret %3
bb2(i64 %4):
    ret %4
}

fn @square(i64 %0) -> i64 {
bb0():
    %1 = imul %0, %0
    ret %1
}

fn @combined(i64 %0, i64 %1) -> i64 {
bb0():
  %2 = call @max(%0, %1)
  %3 = call @square(%2)
  ret %3
}